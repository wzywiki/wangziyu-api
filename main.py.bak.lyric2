# ============================================================
# LRC 歌词代理接口（解决 OSS CORS 问题）
# ============================================================

@app.get("/lyric")
def lyric_proxy(url: str = Query(..., description="OSS LRC 文件 URL")):
    """代理请求 OSS 上的 LRC 文件，解决浏览器 CORS 限制"""
    from urllib.parse import urlparse, quote
    # 只允许代理阿里云 OSS 域名，防止 SSRF
    allowed_hosts = [
        "wzywiki1.oss-cn-guangzhou.aliyuncs.com",
        "wzywiki1.oss-cn-guangzhou-internal.aliyuncs.com",
    ]
    try:
        parsed = urlparse(url)
        if parsed.netloc not in allowed_hosts:
            return Response(content="不允许的域名", status_code=403, media_type="text/plain; charset=utf-8")
        # 对路径中的中文和空格进行 URL 编码（保留已编码的 %xx 不重复编码）
        safe_path = quote(parsed.path, safe="/%")
        safe_query = quote(parsed.query, safe="=&%") if parsed.query else ""
        encoded_url = f"{parsed.scheme}://{parsed.netloc}{safe_path}"
        if safe_query:
            encoded_url += f"?{safe_query}"
        req = urllib.request.Request(encoded_url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            content = resp.read().decode("utf-8", errors="replace")
        return Response(
            content=content,
            media_type="text/plain; charset=utf-8",
            headers={"Cache-Control": "public, max-age=86400"},
        )
    except urllib.error.HTTPError as e:
        return Response(content=f"OSS 请求失败: {e.code}", status_code=502, media_type="text/plain")
    except Exception as e:
        return Response(content=f"代理错误: {str(e)}", status_code=500, media_type="text/plain")



@app.get("/imgproxy")
def imgproxy(url: str = Query(...)):
    import urllib.request
    from urllib.parse import urlparse
    allowed_hosts = [
        "i0.hdslb.com", "i1.hdslb.com", "i2.hdslb.com",
        "s1.hdslb.com", "s2.hdslb.com",
    ]
    try:
        parsed = urlparse(url)
        if parsed.netloc not in allowed_hosts:
            return Response(content="not allowed", status_code=403, media_type="text/plain")
        req = urllib.request.Request(
            url,
            headers={
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
                "Referer": "https://www.bilibili.com",
            }
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            content = resp.read()
            content_type = resp.headers.get("Content-Type", "image/jpeg")
        return Response(
            content=content,
            media_type=content_type,
            headers={"Cache-Control": "public, max-age=86400"},
        )
    except Exception as e:
        return Response(content=str(e), status_code=500, media_type="text/plain")


# ============================================================
# AI 对话代理接口（代理 SiliconFlow，隐藏 API Key，支持流式）
# ============================================================

import httpx
from fastapi import Request
from fastapi.responses import StreamingResponse

SILICONFLOW_API_KEY = "sk-sxtcwnnsukfhwksgymgarvryxwtveezpeekehtxwblqwvtam"
SILICONFLOW_BASE_URL = "https://api.siliconflow.cn/v1"

# 仅支持文本对话的模型列表（过滤掉图像/音频/嵌入等模型）
CHAT_MODELS = [
    "deepseek-ai/DeepSeek-V3",
    "deepseek-ai/DeepSeek-R1",
    "deepseek-ai/DeepSeek-V2.5",
    "Qwen/Qwen2.5-72B-Instruct",
    "Qwen/Qwen2.5-32B-Instruct",
    "Qwen/Qwen2.5-14B-Instruct",
    "Qwen/Qwen2.5-7B-Instruct",
    "Qwen/QwQ-32B",
    "Qwen/Qwen3-235B-A22B",
    "Qwen/Qwen3-32B",
    "Qwen/Qwen3-14B",
    "Qwen/Qwen3-8B",
    "THUDM/GLM-4-32B-0414",
    "THUDM/GLM-Z1-32B-0414",
    "Pro/Qwen/Qwen2.5-7B-Instruct",
    "Pro/deepseek-ai/DeepSeek-R1-Distill-Qwen-7B",
    "deepseek-ai/DeepSeek-R1-Distill-Qwen-32B",
    "deepseek-ai/DeepSeek-R1-Distill-Qwen-14B",
    "deepseek-ai/DeepSeek-R1-Distill-Qwen-7B",
    "moonshotai/Kimi-K2-Instruct-0905",
    "internlm/internlm2_5-7b-chat",
]

@app.get("/chat/models")
def chat_models():
    """返回可用的对话模型列表"""
    return ok(CHAT_MODELS)

@app.post("/chat/completions")
async def chat_completions(request: Request):
    """
    代理 SiliconFlow Chat Completions 接口，支持流式和非流式。
    前端直接 POST 到此接口，API Key 存储在服务端，不暴露给浏览器。
    """
    body = await request.json()
    stream = body.get("stream", False)

    headers = {
        "Authorization": f"Bearer {SILICONFLOW_API_KEY}",
        "Content-Type": "application/json",
        "Accept": "text/event-stream" if stream else "application/json",
    }

    if stream:
        async def generate():
            async with httpx.AsyncClient(timeout=120) as client:
                async with client.stream(
                    "POST",
                    f"{SILICONFLOW_BASE_URL}/chat/completions",
                    json=body,
                    headers=headers,
                ) as resp:
                    async for chunk in resp.aiter_bytes():
                        yield chunk

        return StreamingResponse(
            generate(),
            media_type="text/event-stream",
            headers={
                "Cache-Control": "no-cache",
                "X-Accel-Buffering": "no",
            },
        )
    else:
        async with httpx.AsyncClient(timeout=120) as client:
            resp = await client.post(
                f"{SILICONFLOW_BASE_URL}/chat/completions",
                json=body,
                headers=headers,
            )
            return resp.json()

